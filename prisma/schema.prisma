generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───

enum ThreadStatus {
  Unassigned
  Assigned
  InProgress
  WaitingExternal
  WaitingInternal
  PendingHandover
  Done
  Closed
}

enum ThreadPriority {
  P0
  P1
  P2
  P3
}

enum AlertSeverity {
  low
  medium
  high
  critical
}

enum AlertStatus {
  active
  acknowledged
  resolved
}

enum TravelRuleCaseStatus {
  Open
  Investigating
  PendingResponse
  Resolved
  Escalated
}

enum TravelRuleResolutionType {
  info_obtained
  email_sent
  not_required
  escalated
}

enum ProjectStatus {
  planned
  active
  on_hold
  completed
  cancelled
}

enum DailyCheckStatus {
  pending
  pass
  issues_found
  skipped
}

// AuditAction uses plain String — actions are open-ended across modules

enum IncidentSeverity {
  low
  medium
  high
  critical
}

enum IncidentStatus {
  active
  monitoring
  resolved
}

enum CommsSource {
  email
  slack
  jira
  manual
}

enum UserRole {
  admin
  lead
  employee
  auditor
}

enum ScoringConfigStatus {
  draft
  review
  approved
  active
  archived
}

enum EmployeeRole {
  Analyst
  Senior
  Lead
  Manager
}

enum TeamName {
  TransactionOperations
  AdminOperations
  DataOperations
  StakingOps
  Settlements
}

enum TimePeriodType {
  week
  month
  quarter
}

enum ScoreCategory {
  daily_tasks
  projects
  asset_actions
  quality
  knowledge
}

// ─── Core Employee & Org Models ───

model Employee {
  id        String       @id @default(cuid())
  name      String
  email     String       @unique
  role      EmployeeRole // Analyst, Senior, Lead, Manager
  team      TeamName // TransactionOperations, AdminOperations, DataOperations, StakingOps, Settlements
  region    String       @default("Global")
  active    Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  // Relations
  scores                  CategoryScore[]
  knowledgeScores         KnowledgeScore[]
  employeeNotes           EmployeeNote[]
  ownedThreads            CommsThread[]     @relation("ThreadOwner")
  ownershipChangesFrom    OwnershipChange[] @relation("OldOwner")
  ownershipChangesTo      OwnershipChange[] @relation("NewOwner")
  ownershipChangesBy      OwnershipChange[] @relation("ChangedBy")
  alerts                  Alert[]
  auditLogs               AuditLog[]
  threadNotes             ThreadNote[]
  caseNotes               CaseNote[]
  onCallSchedules         OnCallSchedule[]
  ptoRecords              PtoRecord[]
  assignedTasks           DailyTask[]       @relation("TaskAssignee")
  completedTasks          DailyTask[]       @relation("TaskCompleter")
  createdTasks            DailyTask[]       @relation("TaskCreator")
  ledProjects             Project[]         @relation("ProjectLead")
  projectMemberships      ProjectMember[]
  projectUpdates          ProjectUpdate[]
  rotaAssignments         RotaAssignment[]
  activityStatuses        ActivityStatus[]
  reportedIncidents       Incident[]        @relation("IncidentReporter")
  resolvedIncidents       Incident[]        @relation("IncidentResolver")
  rcaResponsibleIncidents Incident[]        @relation("RcaResponsible")
  clientContactsCreated   ClientContactPreference[] @relation("ClientContactCreatedBy")
  user                    User?

  @@index([team, active])
}

// ─── User / Auth ───

model User {
  id         String   @id @default(cuid())
  email      String   @unique
  name       String
  role       UserRole @default(employee)
  password   String // hashed
  employeeId String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee               Employee?       @relation(fields: [employeeId], references: [id])
  workflowEvents         WorkflowEvent[] @relation("WorkflowPerformedBy")
  createdScoringConfigs  ScoringConfig[] @relation("ScoringConfigCreatedBy")
  reviewedScoringConfigs ScoringConfig[] @relation("ScoringConfigReviewedBy")
  approvedScoringConfigs ScoringConfig[] @relation("ScoringConfigApprovedBy")
}

// ─── Scoring System ───

model TimePeriod {
  id        String         @id @default(cuid())
  type      TimePeriodType // week, month, quarter
  startDate DateTime
  endDate   DateTime
  label     String // e.g. "2026-W09", "2026-02"
  createdAt DateTime       @default(now())

  scores          CategoryScore[]
  knowledgeScores KnowledgeScore[]

  @@unique([type, startDate])
}

model CategoryScore {
  id            String        @id @default(cuid())
  employeeId    String
  periodId      String
  category      ScoreCategory // daily_tasks, projects, asset_actions, quality, knowledge
  rawIndex      Float // 0-1 raw performance index
  score         Float // 3-8 clamped score
  configVersion String // scoring config version used
  evidence      Json          @default("[]") // JSON array of evidence links (kept for backward compat with ScoreEvidence)
  metadata      Json          @default("{}") // JSON object with detailed metrics
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  employee      Employee        @relation(fields: [employeeId], references: [id])
  period        TimePeriod      @relation(fields: [periodId], references: [id])
  scoreEvidence ScoreEvidence[]

  @@unique([employeeId, periodId, category])
}

model KnowledgeScore {
  id                       String   @id @default(cuid())
  employeeId               String
  periodId                 String
  operationalUnderstanding Float    @default(0) // 1-10
  assetKnowledge           Float    @default(0) // 1-10
  complianceAwareness      Float    @default(0) // 1-10
  incidentResponse         Float    @default(0) // 1-10
  overallRaw               Float    @default(0) // 1-10 average
  mappedScore              Float    @default(3) // 3-8 mapped
  notes                    String   @default("")
  scoredBy                 String // user who scored
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  employee Employee   @relation(fields: [employeeId], references: [id])
  period   TimePeriod @relation(fields: [periodId], references: [id])

  @@unique([employeeId, periodId])
}

// NOTE: Only one ScoringConfig should be active at a time (active=true).
// Prisma does not support partial unique indexes, so this constraint
// must be enforced at the application level.
model ScoringConfig {
  id           String              @id @default(cuid())
  version      String              @unique
  config       Json // weights, targets, clamp rules, definitions
  active       Boolean             @default(false)
  status       ScoringConfigStatus @default(draft)
  createdById  String
  reviewedById String?
  reviewedAt   DateTime?
  approvedById String?
  approvedAt   DateTime?
  activatedAt  DateTime?
  createdAt    DateTime            @default(now())
  notes        String              @default("")

  createdByUser  User  @relation("ScoringConfigCreatedBy", fields: [createdById], references: [id])
  reviewedByUser User? @relation("ScoringConfigReviewedBy", fields: [reviewedById], references: [id])
  approvedByUser User? @relation("ScoringConfigApprovedBy", fields: [approvedById], references: [id])

  @@index([status])
  @@index([active])
}

model EmployeeNote {
  id          String   @id @default(cuid())
  employeeId  String
  periodLabel String // e.g. "2026-W09"
  content     String
  noteType    String // manager, employee, context (PTO, on-call, incident)
  authorId    String
  createdAt   DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

// ─── Comms & Ownership Module ───

model CommsThread {
  id                 String         @id @default(cuid())
  source             CommsSource    @default(email)
  sourceThreadRef    String // gmail thread id / slack channel+ts / jira issue key
  participants       Json           @default("[]") // JSON array (kept for backward compat with ThreadParticipant)
  clientOrPartnerTag String         @default("")
  subject            String
  priority           ThreadPriority @default(P2)
  status             ThreadStatus   @default(Unassigned) // Unassigned, Assigned, InProgress, WaitingExternal, WaitingInternal, PendingHandover, Done, Closed
  ownerUserId        String?
  secondaryOwnerIds  Json           @default("[]") // JSON array of employee IDs (watchers / collaborators)
  queue              String         @default("Transaction Operations") // Admin Operations, Transaction Operations, Data Operations
  createdAt          DateTime       @default(now())
  lastMessageAt      DateTime       @default(now())
  lastActionAt       DateTime?
  ttoDeadline        DateTime? // Time-to-Ownership deadline
  ttfaDeadline       DateTime? // Time-to-First-Action deadline
  tslaDeadline       DateTime? // Time-since-last-action deadline
  linkedRecords      Json           @default("[]") // JSON: Jira tickets, Confluence, transaction IDs (kept for backward compat with ThreadLinkedRecord)

  owner               Employee?            @relation("ThreadOwner", fields: [ownerUserId], references: [id])
  messages            CommsMessage[]
  ownershipChanges    OwnershipChange[]
  alerts              Alert[]
  notes               ThreadNote[]
  threadParticipants  ThreadParticipant[]
  threadLinkedRecords ThreadLinkedRecord[]

  @@index([ownerUserId])
  @@index([status])
  @@index([queue])
  @@index([createdAt])
  @@index([source, sourceThreadRef])
  @@index([status, queue])
  @@index([ownerUserId, status])
  @@index([priority, ttoDeadline])
  @@index([lastMessageAt])
}

model CommsMessage {
  id          String   @id @default(cuid())
  threadId    String
  timestamp   DateTime @default(now())
  authorName  String
  authorEmail String   @default("")
  authorType  String // external, internal
  bodySnippet String
  bodyLink    String   @default("") // link to full content
  attachments Json     @default("[]") // JSON: [{name, size, type}] (kept for backward compat with MessageAttachment)

  thread             CommsThread         @relation(fields: [threadId], references: [id], onDelete: Cascade)
  messageAttachments MessageAttachment[]

  @@index([threadId])
}

model OwnershipChange {
  id           String   @id @default(cuid())
  threadId     String
  oldOwnerId   String?
  newOwnerId   String?
  changedById  String
  changedAt    DateTime @default(now())
  reason       String   @default("")
  handoverNote String   @default("")

  thread    CommsThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  oldOwner  Employee?   @relation("OldOwner", fields: [oldOwnerId], references: [id])
  newOwner  Employee?   @relation("NewOwner", fields: [newOwnerId], references: [id])
  changedBy Employee    @relation("ChangedBy", fields: [changedById], references: [id])

  @@index([threadId])
  @@index([changedAt])
}

model ThreadNote {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  thread CommsThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author Employee    @relation(fields: [authorId], references: [id])

  @@index([threadId])
}

// ─── New Relation Models (replacing JSON-in-string fields) ───

model ThreadParticipant {
  id       String @id @default(cuid())
  threadId String
  name     String
  email    String @default("")
  role     String // sender, recipient, cc, watcher

  thread CommsThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model ThreadLinkedRecord {
  id         String @id @default(cuid())
  threadId   String
  recordType String // jira, confluence, transaction, incident
  recordId   String
  label      String @default("")
  url        String @default("")

  thread CommsThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
}

model MessageAttachment {
  id         String @id @default(cuid())
  messageId  String
  name       String
  size       Int    @default(0)
  mimeType   String @default("")
  storageRef String @default("")

  message CommsMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model ScoreEvidence {
  id           String  @id @default(cuid())
  scoreId      String
  evidenceType String // jira_ticket, confluence_page, transaction, incident, manual_note
  sourceRef    String  @default("")
  label        String  @default("")
  url          String  @default("")
  verified     Boolean @default(false)

  score CategoryScore @relation(fields: [scoreId], references: [id], onDelete: Cascade)

  @@index([scoreId])
}

model ProjectTag {
  id        String @id @default(cuid())
  projectId String
  tag       String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, tag])
  @@index([projectId])
}

model WalletTag {
  id       String @id @default(cuid())
  walletId String
  tag      String

  wallet StakingWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@unique([walletId, tag])
  @@index([walletId])
}

// ─── Travel Rule Cases ───

model TravelRuleCase {
  id                 String                    @id @default(cuid())
  transactionId      String // Komainu transaction ID
  txHash             String                    @default("")
  direction          String // IN, OUT
  asset              String
  amount             Float
  senderAddress      String                    @default("")
  receiverAddress    String                    @default("")
  matchStatus        String // unmatched, missing_originator, missing_beneficiary
  notabeneTransferId String?
  ownerUserId        String? // primary person responsible for resolving
  status             TravelRuleCaseStatus      @default(Open)
  resolutionType     TravelRuleResolutionType?
  resolutionNote     String                    @default("")
  emailSentTo        String? // counterparty email if resolution was email
  emailSentAt        DateTime?
  slaDeadline        DateTime? // resolution deadline (createdAt + 48h by default)
  createdAt          DateTime                  @default(now())
  updatedAt          DateTime                  @updatedAt
  resolvedAt         DateTime?

  notes  CaseNote[]
  alerts Alert[]

  @@unique([transactionId, matchStatus])
  @@index([ownerUserId])
  @@index([status])
  @@index([createdAt])
  @@index([status, ownerUserId])
  @@index([slaDeadline])
}

model VaspContact {
  id        String   @id @default(cuid())
  vaspDid   String   @unique // Notabene VASP DID (did:ethr:0x...)
  vaspName  String
  email     String
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Client Contact Preferences ───

model ClientContactPreference {
  id                String   @id @default(cuid())
  clientName        String   @unique // Matches CommsThread.clientOrPartnerTag
  displayName       String   @default("") // Friendly name for UI
  preferredChannel  String   @default("email") // email | slack | phone | portal
  primaryEmail      String   @default("")
  secondaryEmail    String   @default("")
  slackChannel      String   @default("") // e.g. #client-acme
  phoneNumber       String   @default("")
  timezone          String   @default("UTC") // IANA timezone
  businessHoursStart String  @default("09:00")
  businessHoursEnd  String   @default("17:00")
  businessDays      String   @default("mon,tue,wed,thu,fri") // CSV of days
  language          String   @default("en")
  // Travel rule specific
  vaspDid           String   @default("") // Links to VaspContact if applicable
  travelRuleContact String   @default("") // Dedicated TR contact email
  // Escalation
  escalationEmail   String   @default("") // For urgent/P0 matters
  escalationPhone   String   @default("")
  // Metadata
  notes             String   @default("")
  tags              String   @default("[]") // JSON array of tags
  active            Boolean  @default(true)
  lastContactedAt   DateTime?
  createdById       String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  createdBy Employee @relation("ClientContactCreatedBy", fields: [createdById], references: [id])

  @@index([clientName])
  @@index([preferredChannel])
  @@index([active])
}

model CaseNote {
  id        String   @id @default(cuid())
  caseId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  case   TravelRuleCase @relation(fields: [caseId], references: [id], onDelete: Cascade)
  author Employee       @relation(fields: [authorId], references: [id])

  @@index([caseId])
}

// ─── Schedule & On-Call ───

model OnCallSchedule {
  id         String   @id @default(cuid())
  employeeId String
  date       DateTime // the calendar day
  team       String // Transaction Operations, Admin Operations, Data Operations
  shiftType  String   @default("primary") // primary, backup
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([date, team, shiftType])
}

model PublicHoliday {
  id        String   @id @default(cuid())
  date      DateTime
  name      String
  region    String   @default("Global") // Global, EMEA, APAC, Americas
  createdAt DateTime @default(now())

  @@unique([date, region])
}

model PtoRecord {
  id         String   @id @default(cuid())
  employeeId String
  startDate  DateTime
  endDate    DateTime
  type       String   @default("annual_leave") // annual_leave, sick, wfh, other
  status     String   @default("approved") // pending, approved, rejected
  notes      String   @default("")
  hibobId    String? // external HiBob time-off ID for sync
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  employee Employee @relation(fields: [employeeId], references: [id])
}

model DailyTask {
  id            String    @id @default(cuid())
  date          DateTime
  team          String // Transaction Operations, Admin Operations, Data Operations
  assigneeId    String?
  title         String
  description   String    @default("")
  priority      String    @default("normal") // low, normal, high, urgent
  status        String    @default("pending") // pending, in_progress, completed, skipped
  category      String    @default("operational") // operational, compliance, client, administrative
  completedAt   DateTime?
  completedById String?
  createdById   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  assignee    Employee? @relation("TaskAssignee", fields: [assigneeId], references: [id])
  completedBy Employee? @relation("TaskCompleter", fields: [completedById], references: [id])
  createdBy   Employee  @relation("TaskCreator", fields: [createdById], references: [id])
}

// ─── Rota / Sub-Team Assignments ───

model SubTeam {
  id          String   @id @default(cuid())
  name        String // e.g. "Team 1", "Team 2", "Team 3"
  parentTeam  String   @default("Transaction Operations") // which top-level team this belongs to
  description String   @default("") // what this sub-team handles
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  assignments RotaAssignment[]
}

model RotaAssignment {
  id            String   @id @default(cuid())
  subTeamId     String
  employeeId    String
  role          String // lead, member
  startDate     DateTime // period start (e.g. Monday of the rotation week)
  endDate       DateTime // period end
  rotationCycle String   @default("weekly") // weekly, monthly, bimonthly
  shiftType     String   @default("standard") // standard, late, weekend
  isWfh         Boolean  @default(false)
  location      String   @default("London") // London, Hong Kong, Jersey
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subTeam  SubTeam  @relation(fields: [subTeamId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([subTeamId, employeeId, startDate])
}

// ─── Projects ───

model Project {
  id          String        @id @default(cuid())
  name        String
  description String        @default("")
  team        String // Transaction Operations, Admin Operations, Data Operations
  leadId      String // team lead responsible
  status      ProjectStatus @default(active)
  priority    String        @default("medium") // low, medium, high, critical
  startDate   DateTime?
  targetDate  DateTime?
  completedAt DateTime?
  progress    Int           @default(0) // 0-100 percentage
  tags        Json          @default("[]") // JSON array of tags (kept for backward compat with ProjectTag)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lead        Employee        @relation("ProjectLead", fields: [leadId], references: [id])
  updates     ProjectUpdate[]
  members     ProjectMember[]
  projectTags ProjectTag[]
}

model ProjectMember {
  id         String   @id @default(cuid())
  projectId  String
  employeeId String
  role       String   @default("contributor") // lead, contributor, reviewer
  createdAt  DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([projectId, employeeId])
}

model ProjectUpdate {
  id        String   @id @default(cuid())
  projectId String
  authorId  String
  content   String
  type      String   @default("progress") // progress, blocker, milestone, note
  progress  Int? // optional progress snapshot at time of update
  createdAt DateTime @default(now())

  project Project  @relation(fields: [projectId], references: [id])
  author  Employee @relation(fields: [authorId], references: [id])
}

// ─── Activity Status / Time Tracking ───

model ActivityStatus {
  id          String    @id @default(cuid())
  employeeId  String
  activity    String // project, bau, queue_monitoring, lunch, break, meeting, admin, training
  detail      String    @default("") // free text e.g. project name, queue name
  startedAt   DateTime  @default(now())
  endedAt     DateTime? // null = currently active
  durationMin Int? // computed on end, in minutes
  createdAt   DateTime  @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])

  @@index([employeeId, startedAt])
  @@index([endedAt])
}

// ─── Alerts ───

model Alert {
  id               String        @id @default(cuid())
  threadId         String?
  employeeId       String?
  travelRuleCaseId String?
  incidentId       String? // link alert to a 3rd party incident
  type             String // tto_breach, ttfa_breach, tsla_breach, ownership_change, ownership_bounce, mistakes_rising, throughput_drop, sla_slipping, travel_rule_sla_breach
  severity         AlertSeverity @default(medium)
  priority         String        @default("P2")
  message          String
  status           AlertStatus   @default(active)
  destination      String        @default("in_app") // slack, email, in_app
  acknowledgedAt   DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime      @default(now())

  thread         CommsThread?    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  employee       Employee?       @relation(fields: [employeeId], references: [id])
  travelRuleCase TravelRuleCase? @relation(fields: [travelRuleCaseId], references: [id], onDelete: Cascade)
  incident       Incident?       @relation(fields: [incidentId], references: [id])

  @@index([threadId])
  @@index([employeeId])
  @@index([travelRuleCaseId])
  @@index([status])
  @@index([type])
  @@index([type, status])
  @@index([severity, status])
}

// ─── 3rd Party Incidents ───

model Incident {
  id                          String                @id @default(cuid())
  title                       String // e.g. "Fireblocks signing service degraded"
  provider                    String // Fireblocks, Ledger, GX, Komainu, Notabene, etc.
  severity                    IncidentSeverity      @default(medium)
  status                      IncidentStatus        @default(active)
  description                 String                @default("")
  impact                      String                @default("") // what ops impact this causes
  startedAt                   DateTime              @default(now())
  resolvedAt                  DateTime?
  reportedById                String // employee who raised it
  resolvedById                String?
  linkedThreadIds             Json                  @default("[]") // JSON array of commsThread IDs
  linkedTransactionIds        Json                  @default("[]") // JSON array of transaction IDs (Komainu)
  // ─── RCA Tracker Fields ───
  rcaStatus                   String                @default("none") // none, raised, awaiting_rca, rca_received, follow_up_pending, closed
  rcaDocumentRef              String                @default("") // link to RCA document
  rcaResponsibleId            String? // person responsible for chasing RCA
  rcaSlaDeadline              DateTime? // SLA for receiving RCA
  rcaReceivedAt               DateTime?
  rcaFollowUpItems            Json                  @default("[]") // JSON array: [{title, status, assigneeId}]
  rcaRaisedAt                 DateTime? // when RCA was formally raised
  // ─── External Provider Ticket Tracking ───
  externalTicketRef           String                @default("") // Jira issue key e.g. "FB-1234", "LEDGER-567"
  externalTicketUrl           String                @default("") // full URL to provider ticket
  externalTicketStatus        String                @default("") // last known status from Jira sync
  externalTicketLastSyncAt    DateTime? // when we last polled the ticket
  externalTicketDisputed      Boolean               @default(false) // true if provider closed prematurely and we dispute
  externalTicketDisputeReason String                @default("") // why we disagree with closure
  updates                     IncidentUpdate[]
  alerts                      Alert[]
  ticketEvents                ExternalTicketEvent[]
  reportedBy                  Employee              @relation("IncidentReporter", fields: [reportedById], references: [id])
  resolvedBy                  Employee?             @relation("IncidentResolver", fields: [resolvedById], references: [id])
  rcaResponsible              Employee?             @relation("RcaResponsible", fields: [rcaResponsibleId], references: [id])
  createdAt                   DateTime              @default(now())
  updatedAt                   DateTime              @updatedAt

  @@index([status])
  @@index([provider])
  @@index([rcaStatus])
  @@index([externalTicketRef])
  @@index([severity, status])
}

model IncidentUpdate {
  id         String   @id @default(cuid())
  incidentId String
  authorId   String
  content    String
  type       String   @default("update") // update, escalation, resolution
  createdAt  DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}

// ─── External Ticket Event Log ───
// Tracks lifecycle events for provider tickets linked to incidents.
// Captures status changes, premature closures, disputes, and reopens.

model ExternalTicketEvent {
  id          String   @id @default(cuid())
  incidentId  String
  event       String // status_changed, provider_closed, disputed, reopen_requested, reopen_confirmed, comment_added
  fromStatus  String   @default("") // previous ticket status
  toStatus    String   @default("") // new ticket status
  performedBy String   @default("") // "jira_sync" for auto-detected, or employee ID for manual actions
  reason      String   @default("") // dispute reason or comment
  jiraComment String   @default("") // comment posted to Jira (if any)
  createdAt   DateTime @default(now())

  incident Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId])
}

// ─── OES Settlements ───

model OesSettlement {
  id                    String    @id @default(cuid())
  settlementRef         String    @unique // settlement reference / cycle ID
  venue                 String    @default("okx") // okx, fireblocks
  clientName            String
  clientAccount         String    @default("")
  asset                 String // BTC, ETH, USDC, SOL, etc.
  amount                Float
  direction             String // custody_to_exchange, exchange_to_custody
  settlementCycle       String    @default("") // e.g. "2026-03-07T09:00Z"
  // Matching: exchange instruction ↔ on-chain tx
  exchangeInstructionId String    @default("") // exchange-side settlement instruction ID
  onChainTxHash         String    @default("") // confirmed on-chain transaction hash
  collateralWallet      String    @default("") // source/dest collateral wallet
  custodyWallet         String    @default("") // source/dest custody wallet
  matchStatus           String    @default("pending") // pending, matched, mismatch, missing_tx, flagged
  matchNote             String    @default("") // mismatch reason or exchange escalation note
  // Delegation (OKX specific)
  delegationStatus      String    @default("n/a") // n/a, delegated, undelegated, pending_delegation
  delegatedAmount       Float     @default(0)
  // Maker/Checker
  status                String    @default("pending") // pending, confirmed, escalated, failed, completed
  makerById             String? // maker who checked
  makerAt               DateTime?
  checkerById           String? // checker who approved
  checkerAt             DateTime?
  escalationNote        String    @default("") // if flagged to exchange
  // Fireblocks OES specific
  fireblockssTxId       String    @default("") // Fireblocks transaction ID
  oesSignerGroup        String    @default("") // approver group used
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([status])
  @@index([matchStatus])
  @@index([clientName])
  @@index([venue])
  @@index([settlementCycle])
}

// ─── USDC On/Off Ramp Requests ───

model UsdcRampRequest {
  id                 String    @id @default(cuid())
  ticketRef          String    @unique @default(cuid()) // ops ticket reference
  clientName         String
  clientAccount      String    @default("")
  direction          String // onramp (USD→USDC), offramp (USDC→USD)
  amount             Float // USDC amount
  fiatCurrency       String    @default("USD")
  fiatAmount         Float? // fiat equivalent
  // Workflow status — tracks the full ops pipeline
  status             String    @default("instruction_received")
  // Onramp: instruction_received → usd_received → usd_receipt_confirmed → usd_sent_to_issuer → usdc_minted → usdc_delivered → completed
  // Offramp: instruction_received → instruction_accepted → usdc_received → usd_conversion_pending → usd_sent → completed
  // Bank & wire
  bankReference      String    @default("") // SWIFT/payment reference
  instructionRef     String    @default("") // client instruction reference
  ssiVerified        Boolean   @default(false) // bank SSI matches file
  ssiDetails         String    @default("") // SSI summary/bank details
  // Wallets
  custodyWalletId    String    @default("") // client's segregated USDC wallet
  holdingWalletId    String    @default("") // internal issuer-linked holding wallet
  // On-chain
  onChainTxHash      String    @default("") // USDC transfer tx hash
  gasWalletOk        Boolean   @default(true) // ETH gas wallet has sufficient balance
  // Issuer
  issuerConfirmation String    @default("") // issuer receipt/mint confirmation ref
  expressEnabled     Boolean   @default(true) // issuer express conversion enabled
  // Fee buffer
  feesFromBuffer     Boolean   @default(true) // fees covered from proprietary buffer
  feeBufferLow       Boolean   @default(false) // buffer running low — needs top-up
  // Maker / Checker
  makerById          String?
  makerAt            DateTime?
  makerNote          String    @default("")
  checkerById        String?
  checkerAt          DateTime?
  checkerNote        String    @default("")
  // Checks completed
  kycAmlOk           Boolean   @default(false)
  walletWhitelisted  Boolean   @default(false)
  // Evidence & notes
  evidence           Json      @default("[]") // JSON array of evidence refs (SWIFT confirmations, issuer reports, etc.)
  notes              String    @default("")
  rejectionReason    String    @default("")
  // Dates
  requestedAt        DateTime  @default(now())
  completedAt        DateTime?
  clientNotifiedAt   DateTime?
  priority           String    @default("normal") // low, normal, high, urgent
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status])
  @@index([clientName])
  @@index([direction])
  @@index([ticketRef])
}

// ─── Branding / White-Label ───

model BrandingConfig {
  id        String   @id @default("singleton")
  appName   String   @default("KOMmand Centre")
  subtitle  String   @default("Ops Management & Comms Hub")
  logoData  String   @default("") // base64 data URL for logo image
  updatedAt DateTime @updatedAt
}

// ─── Audit ───

model AuditLog {
  id         String   @id @default(cuid())
  action     String // open-ended: config_change, manual_score, ownership_change, status_change, export, login, etc.
  entityType String // scoring_config, employee, thread, knowledge_score
  entityId   String
  userId     String
  details    Json     @default("{}") // JSON
  createdAt  DateTime @default(now())

  user Employee @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@index([entityType, entityId])
}

// ─── Staking Operations ───

model StakingWallet {
  id                      String    @id @default(cuid())
  walletAddress           String    @unique
  asset                   String // BTC, ETH, SOL, DOT, etc.
  validator               String    @default("")
  stakedAmount            Float     @default(0)
  rewardModel             String // auto, daily, weekly, monthly, manual_claim, rebate
  clientName              String    @default("")
  isColdStaking           Boolean   @default(false)
  isTestWallet            Boolean   @default(false)
  stakeDate               DateTime?
  expectedFirstRewardDate DateTime?
  actualFirstRewardDate   DateTime?
  lastRewardAt            DateTime?
  expectedNextRewardAt    DateTime?
  onChainBalance          Float? // for reconciliation
  platformBalance         Float? // internal representation
  varianceThreshold       Float     @default(0.01) // flag if variance > this
  tags                    Json      @default("[]") // JSON: test wallet, known deviations, minimum threshold (kept for backward compat with WalletTag)
  notes                   String    @default("")
  status                  String    @default("active") // active, unstaking, inactive
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  walletTags WalletTag[]

  @@index([asset])
  @@index([rewardModel])
  @@index([status])
}

// ─── Daily Ops Checks ───

model DailyCheckRun {
  id          String    @id @default(cuid())
  date        DateTime  @unique // one run per day
  operatorId  String // employee running the checks
  completedAt DateTime?
  jiraSummary String    @default("") // generated summary text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  items DailyCheckItem[]

  @@index([date])
}

model DailyCheckItem {
  id           String           @id @default(cuid())
  runId        String
  name         String // e.g. "Stuck Transactions"
  category     String // stuck_tx, balance_variance, staking_rewards, screening, travel_rule, pending_approvals, scam_dust, validator_health, external_provider
  status       DailyCheckStatus @default(pending)
  autoCheckKey String           @default("") // key for auto-pass logic
  autoResult   String           @default("") // JSON result from auto-check
  notes        String           @default("")
  operatorId   String? // who completed this item
  completedAt  DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  run DailyCheckRun @relation(fields: [runId], references: [id])

  @@index([runId])
  @@index([category])
}

// ─── Screening & Scam/Dust ───

model ScreeningEntry {
  id                     String    @id @default(cuid())
  transactionId          String    @unique // Komainu transaction ID
  txHash                 String    @default("")
  asset                  String
  amount                 Float     @default(0)
  direction              String    @default("IN") // IN, OUT
  screeningStatus        String    @default("not_submitted") // submitted, processing, completed, not_submitted, exception
  classification         String    @default("unclassified") // unclassified, legitimate, dust, scam
  isKnownException       Boolean   @default(false)
  exceptionReason        String    @default("")
  analyticsAlertId       String    @default("") // chain analytics alert ref
  analyticsStatus        String    @default("none") // none, open, under_review, resolved
  complianceReviewStatus String    @default("none") // none, pending, approved, rejected
  reclassifiedAt         DateTime?
  reclassifiedById       String?
  notes                  String    @default("")
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  @@index([screeningStatus])
  @@index([classification])
  @@index([asset])
}

// ─── Approval Audit Trail ───

model ApprovalAuditEntry {
  id            String   @id @default(cuid())
  requestId     String // Komainu request ID
  action        String // approved, escalated, flagged_stuck
  performedById String
  riskLevel     String   @default("medium") // low, medium, high
  notes         String   @default("")
  createdAt     DateTime @default(now())

  @@index([requestId])
  @@index([performedById])
}

// ─── Token Review & Onboarding ───

model TokenReview {
  id                 String              @id @default(cuid())
  symbol             String // e.g. "BTC", "ETH", "SOL"
  name               String // e.g. "Bitcoin", "Ethereum"
  network            String              @default("") // e.g. "Ethereum", "Solana", "Polkadot"
  contractAddress    String              @default("") // for ERC-20/SPL tokens
  tokenType          String              @default("native") // native, erc20, spl, substrate, other
  // Review pipeline
  status             String              @default("proposed") // proposed, under_review, compliance_review, approved, rejected, live
  proposedById       String? // employee who proposed
  proposedAt         DateTime            @default(now())
  reviewedById       String? // ops reviewer
  reviewedAt         DateTime?
  complianceById     String? // compliance reviewer
  complianceAt       DateTime?
  approvedAt         DateTime?
  rejectedAt         DateTime?
  liveAt             DateTime? // when token went live in custody
  rejectionReason    String              @default("")
  // Risk & compliance assessment
  riskLevel          String              @default("medium") // low, medium, high, critical
  riskNotes          String              @default("") // free-form risk assessment
  regulatoryNotes    String              @default("") // regulatory considerations
  sanctionsCheck     Boolean             @default(false) // sanctions screening completed
  amlRiskAssessed    Boolean             @default(false) // AML risk assessed
  // Custody support details
  custodianSupport   String              @default("[]") // JSON: ["Fireblocks", "Ledger"] — which custodians support it
  stakingAvailable   Boolean             @default(false)
  // Third-party vendor support tracking
  chainalysisSupport String              @default("unknown") // supported, partial, not_supported, unknown
  notabeneSupport    String              @default("unknown") // supported, partial, not_supported, unknown
  fireblocksSupport  String              @default("unknown") // supported, partial, not_supported, unknown
  ledgerSupport      String              @default("unknown") // supported, partial, not_supported, unknown
  vendorNotes        String              @default("") // JSON: per-vendor notes/caveats
  // Institutional demand
  demandScore        Int                 @default(0) // 0-100 computed from demand signals
  demandSignals      TokenDemandSignal[]
  // AI research persistence
  aiResearchResult   String              @default("") // JSON: full AI research output
  aiResearchedAt     DateTime? // when AI research was last run
  aiRecommendation   String              @default("") // approve, approve_with_conditions, further_review, reject
  // Metadata
  marketCapTier      String              @default("unknown") // mega, large, mid, small, micro, unknown
  notes              String              @default("")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([symbol, network])
  @@index([status])
  @@index([riskLevel])
  @@index([demandScore])
}

model TokenDemandSignal {
  id            String   @id @default(cuid())
  tokenReviewId String
  signalType    String // client_request, market_trend, competitor_listed, internal_proposal
  source        String   @default("") // client name, market report, etc.
  description   String   @default("")
  weight        Int      @default(1) // 1-5 strength of signal
  recordedById  String?
  createdAt     DateTime @default(now())

  tokenReview TokenReview @relation(fields: [tokenReviewId], references: [id])

  @@index([tokenReviewId])
}

// ─── Workflow Event History ───

model WorkflowEvent {
  id            String   @id @default(cuid())
  entityType    String // thread, case, incident, score, config
  entityId      String
  eventType     String // status_change, assignment, escalation, resolution, etc.
  fromState     String?
  toState       String?
  performedById String?
  reason        String   @default("")
  metadata      Json?
  createdAt     DateTime @default(now())

  performedBy User? @relation("WorkflowPerformedBy", fields: [performedById], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@index([entityType, entityId, createdAt])
}

// ─── Data Retention ───

model DataRetentionPolicy {
  id             String   @id @default(cuid())
  entityType     String   @unique // audit_log, thread_note, alert, export, incident, etc.
  retentionDays  Int // how many days to retain
  archiveEnabled Boolean  @default(false)
  purgeEnabled   Boolean  @default(false)
  description    String   @default("")
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

// ─── Webhook Events (replay safety / deduplication) ───

model WebhookEvent {
  id            String    @id @default(cuid())
  source        String // slack, jira, fireblocks, etc.
  eventId       String // source-system event ID for dedup
  eventType     String // event type from source
  payload       Json // raw webhook payload
  signature     String    @default("") // webhook signature for verification
  status        String    @default("received") // received, processing, processed, failed, rejected_duplicate
  processedAt   DateTime?
  failureReason String    @default("")
  createdAt     DateTime  @default(now())

  @@unique([source, eventId])
  @@index([source, status])
  @@index([createdAt])
}

// ─── Session Metadata (session hardening) ───

model SessionMetadata {
  id           String    @id @default(cuid())
  userId       String
  sessionToken String    @unique
  ipAddress    String    @default("")
  userAgent    String    @default("")
  lastActiveAt DateTime  @default(now())
  expiresAt    DateTime
  revokedAt    DateTime?
  revokeReason String    @default("")
  createdAt    DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// ─── Transaction Confirmation Flow ───

enum TransactionRiskLevel {
  low
  medium
  high
  critical
}

enum ConfirmationStatus {
  pending
  acknowledged
  signed_off
  escalated
  expired
}

model TransactionConfirmation {
  id                String             @id @default(cuid())
  transactionId     String // Komainu transaction ID
  requestId         String? // Komainu request ID (if applicable)
  riskLevel         TransactionRiskLevel @default(medium)
  asset             String
  amount            Float
  direction         String // IN, OUT
  account           String             @default("")
  workspace         String             @default("")
  // Confirmation tracking
  status            ConfirmationStatus @default(pending)
  acknowledgedById  String?
  acknowledgedAt    DateTime?
  signedOffById     String?
  signedOffAt       DateTime?
  escalatedById     String?
  escalatedAt       DateTime?
  escalationReason  String             @default("")
  // Notification tracking
  slackNotifiedAt   DateTime?
  slackChannel      String             @default("")
  slackMessageTs    String             @default("") // Slack message timestamp for threading
  emailNotifiedAt   DateTime?
  emailSentTo       String             @default("") // comma-separated emails
  // Metadata
  expiresAt         DateTime? // auto-expire unacknowledged confirmations
  notes             String             @default("")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@unique([transactionId])
  @@index([status])
  @@index([riskLevel])
  @@index([riskLevel, status])
  @@index([createdAt])
  @@index([expiresAt])
}

// ─── Feature Flags ───

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "background_jobs", "sse_notifications"
  name        String // Human-readable name
  description String   @default("")
  enabled     Boolean  @default(false)
  // Targeting
  roles       String   @default("[]") // JSON array of roles that can see this feature
  teams       String   @default("[]") // JSON array of teams
  percentage  Int      @default(100) // rollout percentage 0-100
  // Metadata
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([enabled])
}

// ─── Background Job Queue ───

enum JobStatus {
  pending
  running
  completed
  failed
  retrying
}

model BackgroundJob {
  id          String    @id @default(cuid())
  type        String // sync_slack, sync_email, sync_jira, check_sla, check_staking, poll_komainu
  status      JobStatus @default(pending)
  payload     Json      @default("{}") // job-specific configuration
  result      Json?     // job output
  error       String    @default("")
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  nextRunAt   DateTime  @default(now())
  startedAt   DateTime?
  completedAt DateTime?
  // Schedule
  cronExpression String @default("") // e.g. "*/5 * * * *" for every 5 mins
  isRecurring Boolean   @default(false)
  lastRunAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, nextRunAt])
  @@index([type])
  @@index([isRecurring, status])
}
