# Database (PostgreSQL — required for both local dev and production)
# Local: DATABASE_URL="postgresql://postgres:postgres@localhost:5432/kommand"
# Railway: auto-injected by Postgres plugin
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Authentication (NextAuth.js)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-key-change-in-production
# Set to your Railway public URL for production (e.g. https://your-app.up.railway.app)
NEXTAUTH_URL=http://localhost:3000

# Jira Integration (fill in for production)
JIRA_BASE_URL=
JIRA_API_TOKEN=
JIRA_EMAIL=

# Confluence Integration
CONFLUENCE_BASE_URL=
CONFLUENCE_API_TOKEN=
CONFLUENCE_EMAIL=

# Slack Integration
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=
SLACK_CHANNELS=C01234ABCDE,C05678FGHIJ

# Email Integration (IMAP)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=ops-inbox@yourcompany.com
IMAP_PASSWORD=your-app-password
IMAP_TLS=true

# Email Notifications (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=ops-inbox@yourcompany.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=ops@yourcompany.com
SMTP_SECURE=false

# Fireblocks Integration
FIREBLOCKS_API_KEY=
FIREBLOCKS_API_SECRET=

# Komainu API Integration
# Base URL: https://api.komainu.io (production) or https://api-demo.komainu.io (test)
KOMAINU_API_BASE_URL=https://api.komainu.io
KOMAINU_API_USER=
KOMAINU_API_SECRET=

# Notabene Travel Rule Integration
# Base URL: https://api.notabene.id (production) or https://api.notabene.dev (sandbox)
NOTABENE_API_BASE_URL=https://api.notabene.id
NOTABENE_API_TOKEN=
NOTABENE_VASP_DID=did:ethr:0x...

# AI Provider (groq, anthropic, or ollama)
AI_PROVIDER=groq
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
